# Copie para a raiz do projeto na instância AWS:
#   cp deploy/.env.production.example .env.production
#
# DNS (registro A):
#   lia.crescere.life  →  18.191.145.116
DOMAIN=lia.crescere.life

# OpenAI — prioridade sobre credenciais do /admin
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_WHISPER_MODEL=whisper-1
OPENAI_MAX_TOKENS=1024
OPENAI_TEMPERATURE=0.7
OPENAI_TTS_MODEL=tts-1
OPENAI_TTS_VOICE=nova

DEFAULT_TENANT_SLUG=crescere
DEFAULT_TENANT_NAME=Crescere
